class Solution {
public:
    vector<int> countOppositeParity(vector<int>& nums) {
        int n = nums.size();
        int total_even = 0 , total_odd = 0 ;

        //counts of total even and odd elements

        for(int i = 0 ; i<n ; i++){
            if(nums[i] % 2 == 0){
                total_even++;
            }
            else{
                total_odd++;
            }
        }
        vector<int>res(n);

        for(int i = 0 ; i<n  ; i++){
            if(nums[i]%2 == 0){
                res[i] = total_odd;
                total_even--;
            }
            else{
                res[i]= total_even;
                total_odd--;
            }
        }

        return res;

        
        
    }
}
