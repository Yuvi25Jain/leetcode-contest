#include <bits/stdc++.h>
using namespace std;

class Solution {
public:
    vector<int> validElements(vector<int>& nums) {
        int n = nums.size();
        vector<int> ans;

        // Precompute prefix max and suffix max
        vector<int> prefixMax(n), suffixMax(n);
        prefixMax[0] = nums[0];
        for (int i = 1; i < n; i++) prefixMax[i] = max(prefixMax[i-1], nums[i]);

        suffixMax[n-1] = nums[n-1];
        for (int i = n-2; i >= 0; i--) suffixMax[i] = max(suffixMax[i+1], nums[i]);

        // First element always valid
        ans.push_back(nums[0]);

        // Middle elements
        for (int i = 1; i < n - 1; i++) {
            if (nums[i] > prefixMax[i-1] || nums[i] > suffixMax[i+1]) {
                ans.push_back(nums[i]);
            }
        }

        // Last element always valid
        ans.push_back(nums[n-1]);

        return ans;
    }
};
